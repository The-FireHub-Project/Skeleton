{
    "name": "firehub/skeleton",
    "description": "Skeleton App for FireHub Web Application Framework",
    "type": "project",
    "keywords": ["php", "skeleton", "firehub"],
    "homepage": "https://the-firehub-project.github.io/",
    "license": "OSL-3.0",
    "require": {
        "php": "^8.5",
        "firehub/core-standard": "~0.1"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^12.0",
        "pestphp/pest": "^4",
        "pestphp/pest-plugin-type-coverage": "^4",
        "pestphp/pest-plugin-stressless": "^4",
        "pestphp/pest-plugin-profanity": "^4",
        "pestphp/pest-plugin-browser": "^4",
        "pestphp/pest-plugin-faker": "^4",
        "pestphp/pest-plugin-arch": "^4",
        "ext-zip": "*",
        "ext-curl": "*",
        "ext-openssl": "*",
        "ext-sockets": "*"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "authors": [
        {
            "name": "Danijel Galić",
            "email": "danijel.galic@outlook.com",
            "homepage": "https://github.com/dieselxxx",
            "role": "Owner"
        }
    ],
    "support": {
        "email": "danijel.galic@outlook.com",
        "issues": "https://github.com/The-FireHub-Project/Skeleton/issues",
        "security": "https://github.com/The-FireHub-Project/Skeleton/security/policy",
        "forum": "https://github.com/orgs/The-FireHub-Project/discussions",
        "source": "https://github.com/The-FireHub-Project/Skeleton"
    },
    "funding": [
        {
            "type": "patreon",
            "url": "https://www.patreon.com/firehub"
        }
    ],
    "config": {
        "process-timeout": 300,
        "preferred-install": {
            "*": "dist"
        },
        "disable-tls": false,
        "secure-http": true,
        "vendor-dir": "vendor",
        "bin-dir": "vendor/bin",
        "prepend-autoloader": false,
        "sort-packages": true
    }
}